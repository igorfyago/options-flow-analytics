{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api-dashboard",
      "runtimeExecutable": "node",
      "runtimeArgs": ["api/server.js"],
      "port": 3000
    },
    {
      "name": "postgres",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "postgres"],
      "port": 5432
    },
    {
      "name": "collector",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "--manifest-path", "collector/Cargo.toml"],
      "port": 0
    }
  ]
}
